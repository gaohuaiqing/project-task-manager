# ========================================
# Claude Code 忽略清单
# ========================================
# 此文件用于告诉 Claude Code 哪些目录和文件不需要扫描分析
# 完全基于 .gitignore 的内容，不包括任何保留规则（以 ! 开头的规则）
#
# 根据用户需求：把 .gitignore 里面的目录和文件强制作为 Claude Code 的忽略清单
# 除非用户明确指定，否则这些目录和文件均不扫描、不分析
# ========================================

# ========================================
# 依赖管理
# ========================================
node_modules/
app/node_modules/
app/server/node_modules/
Test/E2E_AutoTest/node_modules/

# ========================================
# 构建输出
# ========================================
# 统一构建输出目录
Build/
build/

# 传统构建目录（向后兼容）
dist/
app/dist/
app/server/dist/
app/build/
.app/

# ========================================
# 日志文件
# ========================================
# 统一日志目录
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ========================================
# 测试报告与覆盖率
# ========================================
# 统一测试报告目录
Test/reports/
Test/frontend/coverage/
Test/backend/coverage/
*.lcov
.nyc_output/

# E2E 测试输出
Test/E2E_AutoTest/test-results/
Test/E2E_AutoTest/playwright-report/
Test/E2E_AutoTest/playwright/.cache/

# ========================================
# 测试框架
# ========================================
.vitest/
coverage/

# ========================================
# 备份文件
# ========================================
*.backup
*.bak
*.old
*_backup
src-root-backup/
package.json.new

# ========================================
# 临时文件
# ========================================
*.tmp
*.temp
.cache/
.parcel-cache/
Thumbs.db
.DS_Store

# Windows 保留设备名（无效文件，不应提交）
nul
con
prn
aux
clock$
com1
com2
com3
com4
com5
com6
com7
com8
com9
lpt1
lpt2
lpt3
lpt4
lpt5
lpt6
lpt7
lpt8
lpt9

# ========================================
# TypeScript
# ========================================
*.tsbuildinfo

# ========================================
# 环境变量（安全敏感）
# ========================================
.env
.env.local
.env.*.local
.env.production
.env.development
app/server/.env

# ========================================
# 编辑器和工具配置
# ========================================
# 所有编辑器和工具的配置文件及配套文件，一律忽略
.vscode/
.idea/
*.swp
*.swo
*~

# AI 开发工具配置目录
.claude/
.claude-code/
.claude_context/
.playwright-mcp/
.cursorrules
.cursor/
.cursor-cache/
.trae/
.tr/
.aider/
.aider.cache/
.aider.diff.history/
.aider.history
.continue/
.cline/
.github/
.windsurfrules/
.roo/
.spec-workflow/
.claude-ask/
.ai/
.ai.cache/

# ========================================
# AI 聊天历史和会话
# ========================================
*.chat
*.conversation
.claude_history/

# ========================================
# 自动化测试（遗留）
# ========================================
auto-tests/reports/
auto-tests/node_modules/
auto-tests/*.json

# ========================================
# 项目报告和个人文档
# ========================================
# AI 生成的临时报告，记录测试和优化过程，不影响代码功能
docs/reports/

# 归档文件
docs/archive/

# 用户的个人原始想法和跟踪文件
docs/自定义Prompt/

# ========================================
# 其他临时输出
# ========================================
# Docker 部署临时文件
docker-compose.override.yml

# ========================================
# 额外性能优化（减少索引噪音）
# ========================================
# 根目录只保留 README.md 和 CLAUDE.md
README_NEW.md
*.NEW.*

# E2E 测试文档（不需要频繁索引）
Test/E2E_AutoTest/*.md
Test/E2E_AutoTest/tests/**/*.md

# 内部 README 文件
app/server/README.md
app/server/src/repositories/README.md

# 依赖分析文件（不影响开发）
package-lock.json
yarn.lock
pnpm-lock.yaml
