# npm 配置文件
# 优化依赖管理和安装行为

# ============================================
# 依赖提升策略
# ============================================
# true: 所有依赖提升到根目录（默认，适合 workspaces）
# false: 禁用提升，依赖保持在各自 workspace
# shallow: 只提升 workspace 依赖，不提升传递依赖
hoist=true

# 公共依赖提升（优化目录结构）
# 将常用包提升到 node_modules 根目录
publicHoistPattern[]=@types/*
publicHoistPattern[]=*eslint*
publicHoistPattern[]=*prettier*
publicHoistPattern[]=typescript

# ============================================
# 工作空间配置
# ============================================
# 工作空间链接方式
# true: 使用符号链接（节省空间）
# false: 复制文件
workspace-links=true

# ============================================
# 安装优化
# ============================================
# 自动安装对等依赖
auto-install-peers=true

# 严格对等依赖
strict-peer-dependencies=false

# 包安装前使用 npm audit
# audit=false

# ============================================
# 性能优化
# ============================================
# 并发安装数量
fetch-concurrency=6
fetch-retries=3

# 包缓存目录（使用缓存加速安装）
cache=/tmp/npm-cache

# ============================================
# 前端/后端分离优化（可选）
# ============================================
# 如果前后端依赖冲突严重，可以取消注释以下配置：

# 前端特定依赖不提升
# !workspace:app/node_modules/react
# !workspace:app/node_modules/react-dom

# 后端特定依赖不提升
# !workspace:app/server/node_modules/express
