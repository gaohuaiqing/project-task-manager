# Docker 构建忽略文件

# ============================================
# 构建输出目录
# ============================================
Build/
dist/
build/
*.log

# ============================================
# 依赖目录
# ============================================
node_modules/
app/node_modules/
app/server/node_modules/

# ============================================
# 测试文件
# ============================================
Test/
test/
tests/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
*.test.ts
*.spec.ts

# ============================================
# 开发工具配置
# ============================================
.git/
.gitignore
.env
.env.local
.env.*.local
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# 备份文件
# ============================================
*.backup
*.bak
*.old

# ============================================
# 文档和临时文件
# =================================<arg_value>README.md
*.md
docs/
.DS_Store
Thumbs.db

# ============================================
# 日志文件
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# 其他
# ============================================
.editorconfig
.prettierrc
.eslintrc*
.clang-format
CODE_OF_CONDUCT.md
CONTRIBUTING.md
LICENSE
