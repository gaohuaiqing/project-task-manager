{
  "name": "project-task-manager",
  "version": "1.0.0",
  "description": "企业级项目任务管理系统 - 支持WBS分解、多部门协作、实时数据同步",
  "private": true,
  "workspaces": [
    "app",
    "app/server"
  ],
  "scripts": {
    "===================================": "紧急恢复",
    "dev": "concurrently \"npm:dev:*\" --names \"FRONTEND,BACKEND\"",
    "dev:frontend": "cd app && node --max-old-space-size=4096 ../node_modules/vite/bin/vite.js --port 5173",
    "dev:backend": "cd app/server && node --max-old-space-size=4096 ../../node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "dev:frontend:only": "cd app && vite",
    "dev:backend:only": "cd app/server && tsx watch src/index.ts",
    "build": "npm run build:clean && npm run build:all",
    "build:clean": "rimraf Build/frontend Build/backend",
    "build:all": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd app && vite build --outDir ../Build/frontend/dist",
    "build:backend": "cd app/server && tsc",
    "build:watch": "concurrently \"npm:build:frontend -- --watch\" \"npm:build:backend -- --watch\"",
    "install:all": "npm install",
    "install:clean": "rimraf **/node_modules node_modules && npm install",
    "install:check": "npx depcheck",
    "install:update": "npx npm-check-updates -u",
    "outdated": "npm outdated",
    "deduplicate": "npm dedupe",
    "db:init": "cd app/server && npm run db:init",
    "db:migrate": "cd app/server && npm run migrate:up",
    "db:rollback": "cd app/server && npm run migrate:down",
    "db:status": "cd app/server && npm run migrate:status",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd app && vitest run",
    "test:frontend:watch": "cd app && vitest watch",
    "test:frontend:ui": "cd app && vitest --ui",
    "test:frontend:coverage": "cd app && vitest run --coverage",
    "test:backend": "cd app/server && npm run test:all",
    "test:e2e": "cd app && playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd app && eslint . --ext .ts,.tsx",
    "lint:backend": "cd app/server && eslint . --ext .ts",
    "lint:fix": "npm run lint:frontend -- --fix && npm run lint:backend -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "cd app && tsc --noEmit",
    "typecheck:backend": "cd app/server && tsc --noEmit",
    "deploy": "npm run build && npm run deploy:start",
    "deploy:start": "pm2 reload ecosystem.config.js",
    "deploy:stop": "pm2 stop ecosystem.config.js",
    "deploy:logs": "pm2 logs task-manager-backend",
    "deploy:status": "pm2 status",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v && docker system prune -f",
    "memory:monitor": "node scripts/memory-monitor.js",
    "memory:auto": "node scripts/auto-memory-monitor.js",
    "memory:check": "node -e \"console.log(process.memoryUsage())\"",
    "memory:profile": "node --prof --heapsnapshot-signal=2",
    "health:check": "node scripts/health-check.js",
    "emergency:restart": "npm run cleanup:processes && npm run dev",
    "cleanup:processes": "node scripts/cleanup-processes.js",
    "cleanup:cache": "rimraf app/node_modules/.cache **/.vite",
    "cleanup:all": "npm run cleanup:processes && npm run cleanup:cache && npm cache clean --force"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "concurrently": "^8.2.2",
    "depcheck": "^1.4.7",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/project-task-manager"
  },
  "author": "Your Name",
  "license": "MIT",
  "keywords": [
    "task-management",
    "wbs",
    "project-management",
    "react",
    "express",
    "websocket",
    "mysql",
    "monorepo",
    "workspaces"
  ],
  "dependencies": {
    "bcrypt": "^6.0.0"
  }
}
